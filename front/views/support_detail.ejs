<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Detalle del Reporte | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/dashboard.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid px-0">
            <div class="navbar-inner d-flex align-items-center position-relative w-100">
                <a class="navbar-brand d-flex align-items-center me-2" href="/">
                    <img src="/public/img/maxgradeplacapng.png" alt="MaxGrade" class="navbar-logo">
                </a>
                <div class="navbar-actions d-flex align-items-center gap-3 ms-auto">
                    <div class="dropdown">
                                <button class="btn avatar-circle" data-bs-toggle="dropdown" aria-expanded="false">
                            <% if (user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-image">
                            <% } else { %>
                                <span class="avatar-fallback"><%= user && user.nombre ? user.nombre.charAt(0).toUpperCase() : '?' %></span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="#" onclick="window.location.href='/perfil?returnTo='+encodeURIComponent(window.location.pathname); return false;"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="main-content container py-4">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <a href="/support" class="btn btn-link">← Volver a reportes</a>
                    <h2>Reporte: <small class="text-muted">#<%= report.id %></small></h2>
                </div>

                <div class="report-detail-card">
                    <div class="report-meta">
                        <div class="report-avatar">
                            <% if (reporter && reporter.nombre) { %>
                                <%= (reporter.nombre.charAt(0) + (reporter.apellido ? reporter.apellido.charAt(0) : '')).toUpperCase() %>
                            <% } else { %>
                                <%= String(report.usuario_id).slice(0,2).toUpperCase() %>
                            <% } %>
                        </div>
                        <div class="meta-list">
                            <div class="meta-item"><strong>Tipo:</strong> <span class="text-muted"><%= report.tipo_problema %></span></div>
                            <div class="meta-item"><strong>Creado por:</strong> <span class="text-muted"><%= reporter ? (reporter.nombre + ' ' + (reporter.apellido||'')) : report.usuario_id %></span></div>
                            <div class="meta-item"><strong>Asignado a:</strong> <span class="text-muted"><%= report.asignado ? (report.asignado.nombre + ' ' + (report.asignado.apellido||'')) : '—' %></span></div>
                            <div class="meta-item"><strong>Fecha:</strong> <span class="text-muted"><%= new Date(report.fecha_creacion).toLocaleString() %></span></div>
                        </div>
                    </div>

                    <div class="report-description"><strong>Descripción:</strong>
                        <div class="mt-2"><%= report.descripcion %></div>
                    </div>

                    <% if (report.url_evidencia) { %>
                        <div class="mt-3">
                            <strong>Evidencia:</strong>
                            <div class="mt-2">
                                <% if (report.url_evidencia.match(/\.(jpg|jpeg|png|gif|webp)$/i)) { %>
                                    <img src="<%= report.url_evidencia %>" alt="Evidencia" class="img-fluid border rounded">
                                <% } else { %>
                                    <a href="<%= report.url_evidencia %>" target="_blank" class="btn btn-sm btn-outline-primary">Ver evidencia</a>
                                <% } %>
                            </div>
                        </div>
                    <% } %>

                    <div class="mt-3">
                        <label class="form-label">Estado</label>
                        <select id="pageEstado" class="form-select w-50">
                            <option value="abierto" <%= report.estado === 'abierto' ? 'selected' : '' %>>Abierto</option>
                            <option value="en_progreso" <%= report.estado === 'en_progreso' ? 'selected' : '' %>>En progreso</option>
                            <option value="cerrado" <%= report.estado === 'cerrado' ? 'selected' : '' %>>Cerrado</option>
                        </select>
                    </div>

                    <div class="report-actions">
                        <button id="savePageChanges" type="button" class="btn btn-primary">Guardar cambios</button>
                        <a href="/support" class="btn btn-outline-secondary">Volver a lista</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/support.js"></script>
    <script>
        const saveButton = document.getElementById('savePageChanges');
        saveButton.setAttribute('data-report-id', '<%= report.id %>');
        saveButton.addEventListener('click', () => submitReportDetailChanges(saveButton));
    </script>
</body>
</html>
